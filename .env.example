# ============================================
# RK CREATIVE HUB - ENVIRONMENT VARIABLES
# ============================================
#
# This file documents all environment variables.
# Copy the appropriate file to .env:
#   - .env.local     -> Local development
#   - .env.deployment -> Production deployment
#
# VARIABLES WITH VITE_* PREFIX ARE EXPOSED TO BROWSER!
# Backend-only vars are NOT exposed.
#
# ============================================

# ============================================
# FRONTEND CONFIGURATION (VITE_* prefix)
# ============================================

# VITE_API_URL
# The base URL of your backend API server.
# Frontend makes API calls to this URL.
# 
# Local:    http://localhost:5002
# Production: https://api.rkch.tech
# DEFAULT: (none - must be set)
#
VITE_API_URL=

# VITE_GOOGLE_CLIENT_ID
# Google OAuth Client ID for frontend Google Login.
# Get from: Google Cloud Console > APIs & Services > Credentials
# Format: [random-id].apps.googleusercontent.com
# DEFAULT: (none - must be set)
#
VITE_GOOGLE_CLIENT_ID=


# ============================================
# BACKEND CONFIGURATION
# ============================================

# MODE
# Server operation mode:
#   api  - API server only (use with separate frontend hosting)
#   full - API server + serves frontend (single server deployment)
# DEFAULT: api
#
MODE=api

# NODE_ENV
# Runtime environment:
#   development - Enables debug logs, hot reload
#   production  - Optimized, no debug logs
# DEFAULT: production
#
NODE_ENV=production

# PORT
# TCP port where the backend server listens.
# Common ports: 3000, 5000, 5002, 8080
# DEFAULT: 5002
#
PORT=5002

# CLIENT_URLS
# Allowed origins for CORS (Comma-separated).
# The backend accepts requests ONLY from these URLs.
# Include all domains where your frontend is hosted.
#
# Examples:
#   Local:      http://localhost:5173,http://localhost:3000
#   Production: https://rkch.tech,https://www.rkch.tech
#   Both:       https://rkch.tech,https://www.rkch.tech,http://localhost:5173
# DEFAULT: (none - must be set)
#
CLIENT_URLS=


# ============================================
# DATABASE
# ============================================

# MONGODB_URI
# MongoDB connection string.
# Format: mongodb+srv://username:password@cluster.mongodb.net/database
#
# Get from: MongoDB Atlas > Database > Connect > Driver
# Replace username, password, cluster, and database name.
# DEFAULT: (none - must be set)
#
MONGODB_URI=


# ============================================
# JWT (JSON Web Token) CONFIGURATION
# ============================================

# JWT_SECRET
# Secret key used to sign JWT tokens.
# IMPORTANT: Keep this secret! If compromised, attackers can forge tokens.
# Use a long, random string (at least 32 characters).
# Change in production!
# DEFAULT: (none - must be set)
#
JWT_SECRET=

# JWT_EXPIRE
# How long JWT tokens remain valid.
# Format: number + unit (s, m, h, d)
# Examples: 3600s, 60m, 1h, 7d
# DEFAULT: 7d
#
JWT_EXPIRE=7d


# ============================================
# EMAIL CONFIGURATION (SMTP)
# ============================================

# EMAIL_SERVICE
# Email service provider.
# Supported: gmail, outlook, yahoo, smtp, etc.
# DEFAULT: gmail
#
EMAIL_SERVICE=gmail

# EMAIL_USER
# Email address used for sending emails.
# For Gmail: Your full email address (e.g., user@gmail.com)
# DEFAULT: (none - must be set)
#
EMAIL_USER=

# EMAIL_PASSWORD
# Password or App Password for the email account.
#
# For Gmail:
#   1. Enable 2-Factor Authentication on your Google Account
#   2. Go to: https://myaccount.google.com/apppasswords
#   3. Generate an App Password for "Mail"
#   4. Use the 16-character password (remove spaces)
#
# WARNING: This is NOT your regular email password!
# DEFAULT: (none - must be set)
#
EMAIL_PASSWORD=

# EMAIL_FROM
# Display name and email address in "From" field of sent emails.
# Format: "Display Name <email@domain.com>"
# DEFAULT: (none - must be set)
#
EMAIL_FROM=


# ============================================
# GOOGLE OAUTH (Backend)
# ============================================

# GOOGLE_CLIENT_ID
# Google OAuth Client ID for backend authentication.
# Can be same as VITE_GOOGLE_CLIENT_ID or different.
# Get from: Google Cloud Console > APIs & Services > Credentials
# DEFAULT: (none - must be set)
#
GOOGLE_CLIENT_ID=

# GOOGLE_CLIENT_SECRET
# Google OAuth Client Secret.
# Get from: Google Cloud Console > APIs & Services > Credentials
# WARNING: Keep this secret!
# DEFAULT: (none - must be set)
#
GOOGLE_CLIENT_SECRET=

# GOOGLE_REDIRECT_URI
# Callback URL after Google OAuth flow completes.
# Must match one of the "Authorized redirect URIs" in Google Cloud Console.
#
# Examples:
#   Local:      http://localhost:5002/api/auth/google/callback
#   Production: https://api.rkch.tech/api/auth/google/callback
# DEFAULT: (none - must be set)
#
GOOGLE_REDIRECT_URI=


# ============================================
# APPLE SIGN IN
# ============================================

# APPLE_CLIENT_ID
# Your Apple Service ID (not the Team ID).
# Get from: Apple Developer Portal > Sign in with Apple
# DEFAULT: (none - must be set)
#
APPLE_CLIENT_ID=

# APPLE_REDIRECT_URI
# Callback URL after Apple Sign In completes.
# Must be registered in Apple Developer Portal.
#
# Examples:
#   Local:      http://localhost:5173/login
#   Production: https://www.rkch.tech/login
# DEFAULT: (none - must be set)
#
APPLE_REDIRECT_URI=

# APPLE_SCOPES
# Data requested from Apple (space-separated).
# Common: name email
# DEFAULT: name email
#
APPLE_SCOPES=name email


# ============================================
# FACEBOOK OAUTH
# ============================================

# FACEBOOK_APP_ID
# Facebook App ID.
# Get from: Meta for Developers > My Apps > App ID
# DEFAULT: (none - must be set)
#
FACEBOOK_APP_ID=

# FACEBOOK_APP_SECRET
# Facebook App Secret.
# Get from: Meta for Developers > My Apps > App Secret
# WARNING: Keep this secret!
# DEFAULT: (none - must be set)
#
FACEBOOK_APP_SECRET=

# FACEBOOK_GRAPH_VERSION
# Facebook Graph API version to use.
# Check Meta for Developers for latest version.
# DEFAULT: v19.0
#
FACEBOOK_GRAPH_VERSION=v19.0


# ============================================
# QUICK REFERENCE - DEFAULT VALUES
# ============================================
#
# Variable              Default        Must Set?
# ----------------------------------------------
# MODE                  api            No
# NODE_ENV              production     No
# PORT                  5002           No
# JWT_EXPIRE            7d             No
# EMAIL_SERVICE         gmail          No
# APPLE_SCOPES          name email     No
# FACEBOOK_GRAPH_VERSION v19.0          No
#
# VITE_API_URL          (none)         YES
# VITE_GOOGLE_CLIENT_ID (none)         YES
# CLIENT_URLS            (none)         YES
# MONGODB_URI           (none)         YES
# JWT_SECRET            (none)         YES
# EMAIL_USER            (none)         YES
# EMAIL_PASSWORD        (none)         YES
# EMAIL_FROM            (none)         YES
# GOOGLE_CLIENT_ID      (none)         YES
# GOOGLE_CLIENT_SECRET  (none)         YES
# GOOGLE_REDIRECT_URI   (none)         YES
# APPLE_CLIENT_ID       (none)         YES
# APPLE_REDIRECT_URI    (none)         YES
# FACEBOOK_APP_ID       (none)         YES
# FACEBOOK_APP_SECRET   (none)         YES
#
# ============================================
#
# Environment          VITE_API_URL              CLIENT_URLS
# ----------------------------------------------------------------
# Local Development    http://localhost:5002     http://localhost:5173
# Production           https://api.rkch.tech     https://rkch.tech,https://www.rkch.tech
#
# ============================================
